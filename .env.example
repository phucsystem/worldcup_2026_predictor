# Database
DATABASE_URL=postgresql+psycopg://wc:wc@localhost:5432/worldcup

# API-Football (https://www.api-football.com/)
API_FOOTBALL_KEY=your_key_here
API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io
# FIFA World Cup = league 1. Free plans only cover seasons 2021–2023, so use
# 2022 (real Qatar WC data) for a working demo. Season 2026 needs a paid plan.
API_FOOTBALL_LEAGUE=1
API_FOOTBALL_SEASON=2022

# DeepSeek (OpenAI-compatible)
DEEPSEEK_API_KEY=your_key_here

# Social discussion highlights (optional). The "What fans are saying" panel is
# gated on these: with NO Reddit and NO Bluesky creds the backfill no-ops and the
# panel stays dark. Either source alone is enough; curation also needs
# DEEPSEEK_API_KEY. SOCIAL_* tuning knobs (lookahead, caps) have defaults in
# backend/app/config.py — override there/here only if needed.
# Reddit: create a "script" app at https://www.reddit.com/prefs/apps (client_credentials).
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
# REDDIT_USER_AGENT defaults to wc2026-social/0.1; override only if needed.
# Bluesky: your handle + an App Password (Settings → App Passwords), NOT the account password.
BLUESKY_IDENTIFIER=
BLUESKY_APP_PASSWORD=
# News source needs no credentials — it reads RSS/Atom feeds from a JSON config
# (default: backend/app/social/news_feeds.json). Set SOCIAL_NEWS_FEEDS_FILE to a
# path (e.g. a file mounted on the VM) to change feeds without rebuilding the image.
# SOCIAL_NEWS_FEEDS_FILE=/path/to/news_feeds.json
# X (Twitter): posts are collected off-box by infra/collect-x-posts.py (X's API is
# paid) and dropped onto the VM; the collector reads this JSON file and folds them
# into curation. Stale files (> SOCIAL_X_MAX_AGE_HOURS) are ignored. Prod wires this
# via docker-compose.prod.yml; set here only for local testing.
# SOCIAL_X_CANDIDATES_FILE=/app/social-data/x_candidates.json

# LangSmith observability (optional). Tracing stays OFF unless TRACING=true AND a
# key is set, so leaving these as-is keeps runs fully untraced. TRACING=false is
# the kill switch. ENV is a trace tag only (dev|prod). See docs/deployment-guide.md.
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=worldcup-2026
LANGSMITH_ENV=dev

# Output timezone for daily brief
BRIEF_TIMEZONE=Australia/Melbourne

# Scheduler cadence. Dev defaults to 1800 (30 min); production uses 21600 (6 h)
# to cap DeepSeek/API-Football spend — the main variable cost. Tune to match-day.
SCHEDULER_INTERVAL_SECONDS=1800

# Production only (VM .env): public hostname Caddy serves + provisions TLS for.
# A real domain or a free *.sslip.io name against the VM public IP.
# SITE_ADDRESS=wc2026.example.com
