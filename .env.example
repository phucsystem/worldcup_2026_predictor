# Database
DATABASE_URL=postgresql+psycopg://wc:wc@localhost:5432/worldcup

# API-Football (https://www.api-football.com/)
API_FOOTBALL_KEY=your_key_here
API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io
# FIFA World Cup = league 1. Free plans only cover seasons 2021–2023, so use
# 2022 (real Qatar WC data) for a working demo. Season 2026 needs a paid plan.
API_FOOTBALL_LEAGUE=1
API_FOOTBALL_SEASON=2022

# DeepSeek (OpenAI-compatible)
DEEPSEEK_API_KEY=your_key_here

# LangSmith observability (optional). Tracing stays OFF unless TRACING=true AND a
# key is set, so leaving these as-is keeps runs fully untraced. TRACING=false is
# the kill switch. ENV is a trace tag only (dev|prod). See ck_docs/deployment-guide.md.
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=worldcup-2026
LANGSMITH_ENV=dev

# Output timezone for daily brief
BRIEF_TIMEZONE=Australia/Melbourne

# Scheduler cadence. Dev defaults to 1800 (30 min); production uses 21600 (6 h)
# to cap DeepSeek/API-Football spend — the main variable cost. Tune to match-day.
SCHEDULER_INTERVAL_SECONDS=1800

# Production only (VM .env): public hostname Caddy serves + provisions TLS for.
# A real domain or a free *.sslip.io name against the VM public IP.
# SITE_ADDRESS=wc2026.example.com
